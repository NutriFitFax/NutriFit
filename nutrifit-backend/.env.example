# Copy to .env for local dev:  cp .env.example .env

# "development" | "staging" | "production". Surfaced in /health.
ENVIRONMENT=development

# Comma-separated allowed origins. Use "*" for dev. In production, list the
# real Flutter web/host origins.
CORS_ORIGINS=*

# Outbound HTTP timeout to OpenFoodFacts (seconds).
HTTP_TIMEOUT=8.0

# Optional. Without this, /estimate-meal returns a deterministic stub. With it,
# the endpoint calls OpenAI's vision model. Keep this OUT of git.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Max bytes accepted for /estimate-meal uploads. Default = 8 MiB.
MAX_UPLOAD_BYTES=8388608

# OpenFoodFacts requires a descriptive User-Agent; update if you fork the app.
HTTP_USER_AGENT=NutriFit/0.1 (student project; contact: teamwork@loveiq.org)
