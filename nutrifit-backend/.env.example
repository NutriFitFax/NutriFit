# Copy to .env for local dev:  cp .env.example .env

# "development" | "staging" | "production". Surfaced in /health.
ENVIRONMENT=development

# Comma-separated allowed origins. Use "*" for dev. In production, list the
# real Flutter web/host origins.
CORS_ORIGINS=*

# Outbound HTTP timeout to USDA/OpenAI (seconds).
HTTP_TIMEOUT=8.0

# USDA FoodData Central. DEMO_KEY works for light local testing only; use your
# free data.gov key for team/dev/prod deployments.
USDA_API_KEY=DEMO_KEY
USDA_BASE_URL=https://api.nal.usda.gov/fdc/v1

# Optional. Without this, /estimate-meal returns a deterministic stub. With it,
# the endpoint calls OpenAI's GPT-4o vision model. Keep the real value OUT of git.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Max bytes accepted for /estimate-meal uploads. Default = 8 MiB.
MAX_UPLOAD_BYTES=8388608

# Sent to upstream APIs; update if you fork the app.
HTTP_USER_AGENT=NutriFit/0.1 (student project; contact: teamwork@loveiq.org)
