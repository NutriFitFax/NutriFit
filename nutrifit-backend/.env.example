# Copy to .env for local dev:  cp .env.example .env

# "development" | "staging" | "production". Surfaced in /health.
ENVIRONMENT=development

# Comma-separated allowed origins. Use "*" for dev. In production, list the
# real Flutter web/host origins.
CORS_ORIGINS=*

# Outbound HTTP timeout to USDA/OpenFoodFacts/OpenAI (seconds).
HTTP_TIMEOUT=8.0

# USDA FoodData Central. DEMO_KEY works for light local testing only; use your
# free data.gov key for team/dev/prod deployments.
USDA_API_KEY=DEMO_KEY
USDA_BASE_URL=https://api.nal.usda.gov/fdc/v1

# OpenFoodFacts barcode fallback. Read requests do not need an API key.
OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org

# Required for /meal-plan and /recipes/{id}. Keep the real value OUT of git.
SPOONACULAR_API_KEY=
SPOONACULAR_BASE_URL=https://api.spoonacular.com

# Required for /estimate-meal. Keep the real value OUT of git.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Max bytes accepted for /estimate-meal uploads. Default = 8 MiB.
MAX_UPLOAD_BYTES=8388608

# Sent to upstream APIs; update if you fork the app.
HTTP_USER_AGENT=NutriFit/0.1 (student project; contact: teamwork@loveiq.org)

# Supabase Postgres. Leave blank to disable DB-backed storage; /db-health will
# return {configured:false}. When set, /db-health runs SELECT 1 and /storage/*
# reads/writes profile, meal, water, weight, and activity logs.
# Keep real values OUT of git -- set them in Render only.
# Get the JDBC string from Supabase -> Project Settings -> Database ->
# Connection string -> JDBC (use the Session pooler for serverless backends).
# Example URL: jdbc:postgresql://aws-0-eu-west-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=
# Pooler user is usually postgres.<project-ref>
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=

# Creates the namespaced nutrifit_* tables on startup when DB envs are present.
NUTRIFIT_DB_AUTO_INIT=true
